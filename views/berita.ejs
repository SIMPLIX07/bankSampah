<!doctype html>
<html lang="id">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/layout.css">
    <title>Berita Lingkungan — Bank Sampah</title>

    <style>
        :root {
            --primary: #2E7D32;
            --primary-dark: #1B5E20;
            --primary-light: #E8F5E9;
            --primary-mid: #43A047;
            --accent: #00BFA5;
            --text-dark: #111827;
            --text-muted: #6B7280;
            --bg-light: #F3F7F3;
        }

        * {
            box-sizing: border-box;
        }

        body {
            background: var(--bg-light);
            font-family: 'Inter', sans-serif;
            color: var(--text-dark);
            overflow-x: hidden;
        }

        /* HERO */
        .hero-banner {
            background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 45%, #388E3C 75%, #00695C 100%);
            border-radius: 28px;
            padding: 36px 40px;
            position: relative;
            overflow: hidden;
            margin-bottom: 28px;
            color: white;
        }

        .hero-banner::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 280px;
            height: 280px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 50%;
        }

        .hero-banner::after {
            content: '';
            position: absolute;
            bottom: -80px;
            right: 120px;
            width: 200px;
            height: 200px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 50%;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 30px;
            padding: 5px 14px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.3px;
            margin-bottom: 14px;
        }

        .hero-greeting {
            font-size: 30px;
            font-weight: 900;
            line-height: 1.2;
            margin-bottom: 6px;
        }

        .hero-sub {
            font-size: 14px;
            opacity: 0.8;
            margin-bottom: 28px;
        }

        .hero-mini-stats {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }

        .hero-stat {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255, 255, 255, 0.12);
            border-radius: 16px;
            padding: 12px 18px;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .hero-stat-icon {
            width: 36px;
            height: 36px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .hero-stat-val {
            font-size: 18px;
            font-weight: 800;
            line-height: 1;
        }

        .hero-stat-lbl {
            font-size: 11px;
            opacity: 0.75;
            font-weight: 500;
        }

        /* CARD */
        .card-custom {
            border: none;
            border-radius: 24px;
            background: white;
            box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
            transition: all 0.25s ease;
        }

        .card-custom:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 36px rgba(0, 0, 0, 0.1);
        }

        /* SECTION LABEL */
        .section-label {
            font-size: 11px;
            font-weight: 700;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 4px;
        }

        /* FILTER / CATEGORY TABS */
        .filter-tabs {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .filter-tab {
            padding: 7px 18px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid #e5e7eb;
            background: white;
            color: var(--text-muted);
            transition: all 0.2s;
        }

        .filter-tab.active,
        .filter-tab:hover {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
        }

        /* FEATURED NEWS CARD */
        .news-featured {
            border: none;
            border-radius: 24px;
            overflow: hidden;
            background: white;
            box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
            transition: all 0.25s ease;
            margin-bottom: 28px;
        }

        .news-featured:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 40px rgba(0, 0, 0, 0.1);
        }

        .news-featured-img {
            width: 100%;
            height: 320px;
            object-fit: cover;
            display: block;
        }

        .news-featured-body {
            padding: 28px;
        }

        .news-featured-title {
            font-size: 22px;
            font-weight: 900;
            color: var(--text-dark);
            margin-bottom: 10px;
            line-height: 1.3;
        }

        .news-featured-excerpt {
            font-size: 14px;
            color: var(--text-muted);
            line-height: 1.7;
            margin-bottom: 20px;
        }

        .news-featured-meta {
            display: flex;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
        }

        /* NEWS TAG */
        .news-tag {
            font-size: 11px;
            font-weight: 700;
            padding: 4px 13px;
            border-radius: 20px;
            letter-spacing: 0.3px;
        }

        .news-tag.bencana {
            background: #FFEBEE;
            color: #C62828;
        }

        .news-tag.edukasi {
            background: #E8F5E9;
            color: #2E7D32;
        }

        .news-tag.kebijakan {
            background: #E3F2FD;
            color: #1565C0;
        }

        .news-tag.inovasi {
            background: #FFF8E1;
            color: #F9A825;
        }

        .news-tag.komunitas {
            background: #F3E5F5;
            color: #6A1B9A;
        }

        /* NEWS DATE / SOURCE META */
        .news-meta-info {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--text-muted);
        }

        .news-meta-info i {
            font-size: 13px;
        }

        /* BTN READ */
        .btn-read {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, var(--primary), var(--primary-mid));
            color: white;
            text-decoration: none;
            padding: 9px 22px;
            border-radius: 22px;
            font-size: 13px;
            font-weight: 700;
            transition: opacity 0.2s;
            border: none;
            cursor: pointer;
        }

        .btn-read:hover {
            opacity: 0.88;
            color: white;
        }

        /* STANDARD NEWS CARD */
        .news-card {
            border: none;
            border-radius: 24px;
            background: white;
            box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
            overflow: hidden;
            transition: all 0.25s ease;
            height: 100%;
        }

        .news-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 40px rgba(0, 0, 0, 0.1);
        }

        .news-card-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            display: block;
        }

        .news-card-body {
            padding: 20px;
        }

        .news-card-title {
            font-size: 15px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 8px;
            line-height: 1.4;
        }

        .news-card-excerpt {
            font-size: 13px;
            color: var(--text-muted);
            line-height: 1.6;
            margin-bottom: 16px;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .news-card-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 12px;
            border-top: 1px solid #F3F7F3;
        }

        /* LIST NEWS (sidebar-style) */
        .news-list-item {
            display: flex;
            gap: 14px;
            padding: 14px 0;
            border-bottom: 1px solid #F3F7F3;
            transition: background 0.15s;
            cursor: pointer;
        }

        .news-list-item:last-child {
            border-bottom: none;
        }

        .news-list-item:hover .news-list-title {
            color: var(--primary);
        }

        .news-list-img {
            width: 72px;
            height: 72px;
            border-radius: 14px;
            object-fit: cover;
            flex-shrink: 0;
        }

        .news-list-title {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-dark);
            line-height: 1.4;
            margin-bottom: 5px;
            transition: color 0.2s;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .news-list-date {
            font-size: 11px;
            color: var(--text-muted);
        }

        /* PANEL CARD */
        .panel-card {
            background: white;
            border: none;
            border-radius: 24px;
            box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
            padding: 22px;
            margin-bottom: 20px;
            transition: all 0.25s ease;
        }

        .panel-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 36px rgba(0, 0, 0, 0.1);
        }

        .panel-title {
            font-size: 15px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .panel-title-icon {
            width: 30px;
            height: 30px;
            border-radius: 10px;
            background: var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            color: var(--primary);
        }

        /* ECO STAT CARDS */
        .eco-stat-card {
            border-radius: 20px;
            padding: 20px 22px;
            color: white;
            position: relative;
            overflow: hidden;
            height: 100%;
        }

        .eco-stat-card::after {
            content: '';
            position: absolute;
            bottom: -20px;
            right: -20px;
            width: 90px;
            height: 90px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
        }

        .eco-stat-card.green {
            background: linear-gradient(135deg, #2E7D32, #43A047);
        }

        .eco-stat-card.teal {
            background: linear-gradient(135deg, #00695C, #00897B);
        }

        .eco-stat-card.red {
            background: linear-gradient(135deg, #B71C1C, #E53935);
        }

        .eco-stat-icon {
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin-bottom: 14px;
        }

        .eco-stat-val {
            font-size: 26px;
            font-weight: 900;
            line-height: 1;
            margin-bottom: 4px;
        }

        .eco-stat-lbl {
            font-size: 12px;
            opacity: 0.85;
            font-weight: 500;
        }

        /* FADE IN */
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(18px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-in {
            animation: fadeUp 0.5s ease both;
        }

        .fade-in:nth-child(1) {
            animation-delay: 0.05s;
        }

        .fade-in:nth-child(2) {
            animation-delay: 0.10s;
        }

        .fade-in:nth-child(3) {
            animation-delay: 0.15s;
        }

        .fade-in:nth-child(4) {
            animation-delay: 0.20s;
        }

        .fade-in:nth-child(5) {
            animation-delay: 0.25s;
        }
    </style>
</head>

<body>
    <%- include('./components/navbar', { activePage: 'berita' }) %>
        <%- include('./components/sidebar', { activePage: 'berita' }) %>

            <div class="main-content">

                <!-- HERO -->
