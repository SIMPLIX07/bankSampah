            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                // ── WEIGHT SLIDER ──
                const slider = document.getElementById('weightSlider');
                const weightDsp = document.getElementById('weightDisplay');
                const ptsEst = document.getElementById('pointsEstimate');
                const weightMan = document.getElementById('weightManual');
                const sumBerat = document.getElementById('sumBerat');
                const sumPts = document.getElementById('sumPts');

                function updateWeight(val) {
                    val = Math.max(1, Math.min(10000, parseFloat(val) || 1));
                    slider.value = Math.min(val, 100);
                    weightDsp.textContent = val;
                    const pts = Math.round(val * 5);
                    ptsEst.textContent = '+' + pts + ' Pts';
                    sumBerat.textContent = val + ' kg';
                    sumPts.textContent = '+' + pts;
                    // Update slider gradient
                    const pct = (Math.min(val, 100) / 100) * 100;
                    slider.style.background =
                        `linear-gradient(to right, var(--primary) 0%, var(--primary) ${pct}%, #E5E7EB ${pct}%)`;
                }

                slider.addEventListener('input', () => {
                    weightMan.value = slider.value;
                    updateWeight(slider.value);
                });

                weightMan.addEventListener('input', () => updateWeight(weightMan.value));

                // Quick kg buttons
                document.querySelectorAll('.quick-kg-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        document.querySelectorAll('.quick-kg-btn').forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
                        const v = parseInt(btn.dataset.val);
                        weightMan.value = v;
                        updateWeight(v);
                    });
                });

                // Set default quick button
                document.querySelector('.quick-kg-btn[data-val="5"]').classList.add('active');
                updateWeight(5);

                // ── DELIVERY METHOD TOGGLE ──
                const pickupFields = document.getElementById('pickup-fields');
                const dropoffFields = document.getElementById('dropoff-fields');

                document.querySelectorAll('input[name="metode"]').forEach(radio => {
                    radio.addEventListener('change', () => {
                        if (radio.value === 'pickup') {
                            pickupFields.style.display = 'block';
                            dropoffFields.style.display = 'none';
                            document.getElementById('sumMetode').textContent = 'Jemput di Tempat';
                        } else {
                            pickupFields.style.display = 'none';
                            dropoffFields.style.display = 'block';
                            document.getElementById('sumMetode').textContent = 'Antar Sendiri';
                        }
                    });
                });

                // ── JENIS SAMPAH SUMMARY ──
                const namaJenis = {
                    plastik: 'Plastik', kertas: 'Kertas', kaca: 'Kaca',
                    logam: 'Logam', organik: 'Organik', elektronik: 'Elektronik',
                    tekstil: 'Tekstil', minyak: 'Minyak Jelantah'
                };
                document.querySelectorAll('input[name="jenis_sampah[]"]').forEach(cb => {
                    cb.addEventListener('change', () => {
                        const checked = [...document.querySelectorAll('input[name="jenis_sampah[]"]:checked')]
                            .map(c => namaJenis[c.value]);
                        document.getElementById('sumJenis').textContent =
                            checked.length ? checked.join(', ') : '—';
                    });
                });

                // ── JADWAL SUMMARY ──
                const tanggalInput = document.getElementById('tanggalInput');
                // Set min date = today
                tanggalInput.min = new Date().toISOString().split('T')[0];
                tanggalInput.addEventListener('change', updateJadwal);
                document.querySelector('select[name="jam"]').addEventListener('change', updateJadwal);

                function updateJadwal() {
                    const tgl = tanggalInput.value;
                    const jam = document.querySelector('select[name="jam"]').value;
                    if (tgl && jam) {
                        const d = new Date(tgl);
                        const opts = { day: 'numeric', month: 'short', year: 'numeric' };
                        document.getElementById('sumJadwal').textContent =
                            d.toLocaleDateString('id-ID', opts) + ', ' + jam;
                    } else if (tgl) {
                        const d = new Date(tgl);
                        document.getElementById('sumJadwal').textContent =
                            d.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
                    } else {
                        document.getElementById('sumJadwal').textContent = '—';
                    }
                }
            </script>
</body>

