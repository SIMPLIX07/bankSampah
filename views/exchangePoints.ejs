    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const MY_POINTS = 200;

        // ── TAB SWITCH ──
        function switchTab(tab) {
            document.getElementById('panel-katalog').style.display = tab === 'katalog' ? 'block' : 'none';
            document.getElementById('panel-custom').style.display  = tab === 'custom'  ? 'block' : 'none';
            document.getElementById('tab-katalog').classList.toggle('active', tab === 'katalog');
            document.getElementById('tab-custom').classList.toggle('active', tab === 'custom');
            document.getElementById('deliveryMethodField').style.display = tab === 'katalog' ? '' : 'none';

            if (tab === 'custom') {
                updateConversion();
            } else {
                const sel = document.querySelector('.reward-card.selected');
                if (sel) updateSummary(sel.dataset.name, parseInt(sel.dataset.pts));
                else resetSummary();
            }
        }

        // ── REWARD FILTER ──
        function filterReward(btn, cat) {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.querySelectorAll('.reward-card').forEach(c => {
                c.style.display = (cat === 'all' || c.dataset.cat === cat) ? '' : 'none';
            });
        }

        // ── SELECT REWARD ──
        function selectReward(card) {
            document.querySelectorAll('.reward-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            const name = card.dataset.name;
            const pts  = parseInt(card.dataset.pts);
            document.getElementById('hiddenRewardName').value = name;
            document.getElementById('hiddenRewardPts').value  = pts;
            updateSummary(name, pts);
        }

        function updateSummary(name, pts) {
            document.getElementById('sumReward').textContent  = name;
            document.getElementById('sumPtsUsed').textContent = pts + ' Pts';
            const left = MY_POINTS - pts;
            document.getElementById('sumPtsLeft').textContent = left >= 0 ? left + ' Pts' : '⚠ Tidak cukup';
            document.getElementById('sumPtsLeft').style.color = left >= 0 ? '#2E7D32' : '#E65100';
            document.getElementById('sumNilai').textContent   = 'Rp ' + (pts * 1000).toLocaleString('id-ID');
        }

        function resetSummary() {
            document.getElementById('sumReward').textContent  = '—';
            document.getElementById('sumPtsUsed').textContent = '—';
            document.getElementById('sumPtsLeft').textContent = MY_POINTS + ' Pts';
            document.getElementById('sumPtsLeft').style.color = '#2E7D32';
            document.getElementById('sumNilai').textContent   = '—';
        }

        // ── CONVERSION ──
        const ptsKonversiInput = document.getElementById('ptsKonversi');

        function updateConversion() {
            const pts = Math.max(0, parseInt(ptsKonversiInput.value) || 0);
            document.getElementById('convPts').textContent = pts;
            document.getElementById('convRp').textContent  = 'Rp ' + (pts * 1000).toLocaleString('id-ID');
            const left = MY_POINTS - pts;
            document.getElementById('sumReward').textContent  = 'Konversi ke Uang';
            document.getElementById('sumPtsUsed').textContent = pts + ' Pts';
            document.getElementById('sumPtsLeft').textContent = left >= 0 ? left + ' Pts' : '⚠ Tidak cukup';
            document.getElementById('sumPtsLeft').style.color = left >= 0 ? '#2E7D32' : '#E65100';
            document.getElementById('sumNilai').textContent   = 'Rp ' + (pts * 1000).toLocaleString('id-ID');
        }

        ptsKonversiInput.addEventListener('input', updateConversion);

        // Preset pts buttons
        document.querySelectorAll('.pts-preset-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.pts-preset-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                ptsKonversiInput.value = btn.dataset.val;
                updateConversion();
            });
        });
    </script>
