<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <title>Dashboard</title>

    <style>
        :root {
            --primary: #2E7D32;
            --primary-light: #E8F5E9;
            --accent: #2F855A;
            --background: #F4F7F4;
        }

        body {
            background: #ffff;
            font-family: 'Inter', sans-serif;
            font-size: 20px;
            color: #1f2937;
        }

        /* Sidebar */
        .sidebar {
            width: 110px;
            /* sekalian diperbesar */
            background: #ffff;
            position: fixed;
            top: 100px;
            /* beri jarak dari navbar */
            left: 20px;
            /* JARAK DARI KIRI */
            height: calc(100vh - 120px);
            /* sesuaikan */
            border-radius: 25px;
            /* supaya tidak kotak */

            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;

            box-shadow: none;
        }

        .greeting-title {
            font-size: 40px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .sidebar .icon {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 18px 0;
            background: var(--primary-light);
            color: var(--primary);
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 28px;
            /* BESARKAN ICON */
        }

        .sidebar .icon.active {
            background: white;
            color: var(--primary);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
        }

        .sidebar .icon:hover {
            background: var(--primary-light);
            color: var(--accent);
        }

        /* Main wrapper */
        .main {
            margin-left: 160px;
            margin-top: 100px;
            padding: 30px;
            /* tambahkan ini */
        }

        /* Cards */
        .card-custom {
            border: none;
            border-radius: 25px;
            padding: 25px !important;
            background: white;

            box-shadow:
                0 4px 10px rgba(0, 0, 0, 0.04),
                0 10px 25px rgba(0, 0, 0, 0.06);
        }

        .card-custom:hover {
            transform: translateY(-3px);
            box-shadow:
                0 8px 20px rgba(0, 0, 0, 0.06),
                0 20px 40px rgba(0, 0, 0, 0.08);
            transition: all 0.25s ease;
        }


        /* Activity left card */


        .activity-chart {
            height: 120px;
            background: linear-gradient(180deg, #6c63ff 40%, #dfe3ff 40%);
            border-radius: 15px;
            margin-top: 20px;
        }

        /* Balance gradient */
        .points-box {
            background: linear-gradient(135deg, #d5eef6, #c1e5ef);
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        }

        .money-box {
            background: linear-gradient(135deg, #f8f1c7, #f3e79a);
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        }

        h2 {
            font-size: 32px;
            font-weight: 700;
        }

        h5 {
            font-size: 20px;
            font-weight: 600;
        }

        .p-3.rounded-4.bg-light {
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        /* News */
        .news-img {
            width: 100%;
            height: 260px;
            object-fit: cover;
            border-radius: 20px;
        }

        /* Recent activity */
        .table thead {
            font-size: 13px;
            color: #9aa4b2;
        }

        .action-btn {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: white;
            border: none;
            border-radius: 30px;
            padding: 8px 22px;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.3px;

            display: inline-flex;
            align-items: center;
            gap: 6px;

            box-shadow: 0 6px 15px rgba(46, 125, 50, 0.25);

            transition: all 0.25s ease;
        }

        .action-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(46, 125, 50, 0.35);
            background: linear-gradient(135deg, var(--accent), var(--primary));
        }

        .action-btn i {
            font-size: 14px;
        }

        .table td {
            vertical-align: middle;
            padding: 18px 10px;
        }

        .badge-soft {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
        }

        .badge-blue {
            background: #e4f0ff;
            color: #3b82f6;
        }

        .badge-orange {
            background: #fff2e5;
            color: #f97316;
        }

        .badge-purple {
            background: #f3e8ff;
            color: #a855f7;
        }

        .history-btn {
            background: #111827;
            color: white;
            border-radius: 20px;
            padding: 6px 18px;
            font-size: 13px;
        }

        .navbar {
            z-index: 10;
        }

        .table {
            font-size: 15px;
        }

        .table thead {
            font-size: 14px;
            font-weight: 600;
        }

        .nav-link {
            font-size: 16px;
        }

        .activity-wrapper {
            height: 160px;
        }

        .y-axis,
        .bars {
            height: 130px;
            align-items: flex-end;
        }

        .bar-group {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-end;
        }

        .metric-number {
            font-size: 40px;
            font-weight: 700;
            color: var(--primary);
        }

        .bar {
            width: 40px;
            background: #d6d9df;
            border-radius: 20px;
            transition: 0.3s ease;
        }

        .bar:hover {
            background: #6c63ff;
        }

        .balance-number {
            font-size: 28px;
            font-weight: 700;
        }

        .text-primary {
            color: var(--primary) !important;
        }
    </style>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>
    <!-- TOP NAVBAR -->
    <nav class="navbar navbar-expand-lg bg-white px-4 py-3 shadow-sm fixed top">
        <div class="container-fluid">

            <!-- Left Logo -->
            <div class="d-flex align-items-center gap-2">
                <div style="width:35px;height:35px;background:#6c63ff;border-radius:50%;"></div>
                <div>
                    <div class="fw-bold">Bank</div>
                    <div class="fw-bold">Sampah</div>
                </div>
            </div>

            <!-- Menu -->
            <div class="collapse navbar-collapse justify-content-center">
                <ul class="navbar-nav gap-4">
                    <li class="nav-item">
                        <a class="nav-link text-muted fw-semibold" href="#">Deposit Trash</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-muted fw-semibold" href="#">Exchange Points</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-muted fw-semibold" href="#">Withdraw Money</a>
                    </li>
                </ul>
            </div>

            <!-- Right Side -->
            <div class="d-flex align-items-center gap-3">

                <!-- Search -->
                <input type="text" class="form-control rounded-pill bg-light border-0" placeholder="Search"
                    style="width:250px;">

                <!-- Notification -->
                <div
                    style="width:40px;height:40px;background:#f0f2f7;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                    🔔
                </div>

                <!-- Profile -->
                <div class="d-flex align-items-center gap-2">
                    <div style="width:40px;height:40px;background:#c97b42;border-radius:50%;"></div>
                    <div>
                        <div class="fw-bold small">Matt Shadows</div>
                        <div class="text-muted small">Joined 3 Months ago</div>
                    </div>
                </div>

            </div>
        </div>
    </nav>

    <!-- Sidebar -->
    <div class="sidebar">

        <a href="/" class="icon active text-decoration-none" title="Home">
            <i class="bi bi-house"></i>
        </a>

        <a href="/komunitas" class="icon text-decoration-none" title="Komunitas">
            <i class="bi bi-people"></i>
        </a>

        <a href="/berita" class="icon text-decoration-none" title="Berita">
            <i class="bi bi-newspaper"></i>
        </a>

    </div>

    <!-- Main -->
    <div class="main">

        <!-- Top -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="greeting-title">Selamat Datang, Matt!</h1>
                <div class="text-muted">Siap untuk membuat bumi lebih baik lagi?</div>
            </div>

        </div>

        <div class="row g-4">

            <!-- Left Activity -->
            <div class="col-lg-4">
                <div class="card card-custom p-4 activity-card">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h5 class="fw-bold">Total Aktifitas</h5>
                            <small class="text-muted">Lihat seberapa banyak kontribusi Anda!</small>
                        </div>
                        <small class="text-primary">Selengkapnya ></small>
                    </div>

                    <div class="mt-3">
                        <h1 class="metric-number">85%</h1>
                        <small class="text-muted">Lebih baik dari bulan lalu</small>
                    </div>

                    <div class="activity-wrapper mt-4">

                        <div class="d-flex align-items-end">

                            <!-- Y Axis -->
                            <div class="y-axis me-3 text-muted">
                                <div>100</div>
                                <div>75</div>
                                <div>50</div>
                                <div>25</div>
                                <div>0</div>
                            </div>

                            <!-- Bars -->
                            <div class="bars d-flex align-items-end gap-4">

                                <div class="bar-group text-center">
                                    <div class="bar" style="height:80px;"></div>
                                    <small>1-7</small>
                                </div>

                                <div class="bar-group text-center">
                                    <div class="bar" style="height:120px;"></div>
                                    <small>8-14</small>
                                </div>

                                <div class="bar-group text-center">
                                    <div class="bar" style="height:85px;"></div>
                                    <small>14-21</small>
                                </div>

                                <div class="bar-group text-center">
                                    <div class="bar" style="height:120px;"></div>
                                    <small>21-30</small>
                                </div>

                            </div>

                        </div>

                    </div>

                    <div class="mt-3">
                        <div class="p-3 rounded-4 bg-light d-flex justify-content-between">
                            <span>Goals</span>
                            <span>›</span>
                        </div>
                        <div class="p-3 rounded-4 bg-light d-flex justify-content-between mt-4">
                            <span>Rencana bulanan</span>
                            <span>›</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Content -->
            <div class="col-lg-8">

                <!-- Balance -->
                <div class="card card-custom p-4 mb-4">
                    <h5 class="fw-bold">Balance Overview</h5>
                    <small class="text-muted">Tukarkan atau tarik dana Anda!</small>

                    <div class="row mt-3 g-3">
                        <div class="col-md-6">
                            <div class="points-box">
                                <div class="text-muted">Point anda</div>
                                <h3 class="balance-number mt-2">200 Pts</h3>
                                <button class="action-btn mt-2">
                                    <i class="bi bi-arrow-repeat"></i>
                                    Tukar
                                </button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="money-box">
                                <div class="text-muted">Uang anda</div>
                                <h3 class="balance-number mt-2">Rp 200.000</h3>
                                <button class="action-btn mt-2">
                                    <i class="bi bi-cash-coin"></i>
                                    Tarik
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- News -->
                <div class="card card-custom p-4 mb-4">
                    <h5 class="fw-bold">Berita Terpopuler</h5>
                    <small class="text-muted">Pembaruan dari komunitas Anda</small>

                    <img src="https://images.unsplash.com/photo-1509395176047-4a66953fd231" class="news-img mt-4">

                    <div class="mt-4">
                        <span class="badge bg-primary">Komunitas</span>
                        <h5 class="mt-2 fw-bold">New Recycling Center Opens in Bandung</h5>
                        <small class="text-muted">Residents can now bring e-waste starting next Monday...</small>
                    </div>
                </div>

            </div>
        </div>

        <!-- Recent Activity -->
        <div class="card card-custom p-4 mt-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="fw-bold">Aktifitas terbaru</h5>
                    <small class="text-muted">Lihat aktivitas terbaru Anda disini</small>
                </div>
                <button class="history-btn">History</button>
            </div>

            <div class="table-responsive mt-3">
                <table class="table">
                    <thead>
                        <tr>
                            <th>NAME/BUSINESS</th>
                            <th>Tanggal</th>
                            <th>Tipe AKtifitas</th>
                            <th>POINT</th>
                            <th>UANG</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Plastic Donation</td>
                            <td>28 Dec 2025</td>
                            <td><span class="badge-soft badge-blue">Recycling</span></td>
                            <td class="text-success">+200</td>
                            <td>Rp 20.000</td>
                        </tr>
                        <tr>
                            <td>Grocery Rewards</td>
                            <td>27 Dec 2025</td>
                            <td><span class="badge-soft badge-orange">Exchange</span></td>
                            <td class="text-danger">-50</td>
                            <td>Rp 0</td>
                        </tr>
                        <tr>
                            <td>Cash Withdrawal</td>
                            <td>25 Dec 2025</td>
                            <td><span class="badge-soft badge-purple">Withdraw</span></td>
                            <td>0</td>
                            <td>-Rp 50.000</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>