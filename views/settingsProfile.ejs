<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Profile Settings - Bank Sampah</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/layout.css">

    <style>
        body {
            background: #fdfdfd;
            font-family: 'Segoe UI', sans-serif;
            color: #333;
        }

        .settings-container {
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 1px 15px rgba(0, 0, 0, 0.04);
            padding: 30px;
            border: 1px solid #eef0f4;
            margin-bottom: 30px;
            max-width: 1000px;
        }

        .settings-header {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .nav-tabs {
            border-bottom: 1px solid #eaeaea;
            margin-bottom: 30px;
            flex-wrap: nowrap;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            padding-bottom: 2px;
        }

        /* Hide scrollbar for tabs */
        .nav-tabs::-webkit-scrollbar {
            display: none;
        }

        .nav-tabs {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .nav-tabs .nav-link {
            color: #6c757d;
            border: none;
            padding: 10px 15px;
            font-weight: 500;
            margin-bottom: -1px;
            position: relative;
        }

        .nav-tabs .nav-link:hover {
            color: #495057;
            border: none;
        }

        .nav-tabs .nav-link.active {
            color: #111;
            background: transparent;
            border: none;
        }

        .nav-tabs .nav-link.active::after {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            bottom: 0;
            height: 2px;
            background: #2E7D32;
        }

        .section-title {
            font-size: 16px;
            font-weight: 600;
            color: #212529;
            margin-bottom: 5px;
        }

        .section-desc {
            font-size: 14px;
            color: #6c757d;
            margin-bottom: 0;
        }

        .settings-row {
            padding: 25px 0;
            border-bottom: 1px solid #eaeaea;
        }

        .settings-row:last-child {
            border-bottom: none;
        }

        /* Form Controls */
        .form-control-custom {
            border: 1px solid #dcdfe4;
            border-radius: 6px;
            padding: 8px 12px;
            font-size: 14px;
            color: #333;
            width: 100%;
            max-width: 400px;
            background: #fff;
            font-weight: 500;
        }

        textarea.form-control-custom {
            min-height: 100px;
            resize: vertical;
        }

        .form-control-custom:focus {
            outline: none;
            border-color: #2E7D32;
            box-shadow: 0 0 0 3px rgba(68, 76, 231, 0.1);
        }

        .btn-cancel {
            background: white;
            border: 1px solid #dcdfe4;
            color: #344054;
            font-weight: 600;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 14px;
        }

        .btn-cancel:hover {
            background: #f9fafb;
            color: #344054;
        }

        .btn-save {
            background: #2E7D32;
            border: 1px solid #2E7D32;
            color: white;
            font-weight: 600;
            border-radius: 8px;
            padding: 8px 16px;
            margin-left: 12px;
            font-size: 14px;
        }

        .btn-save:hover {
            background: #3538cd;
            color: white;
        }

        /* Avatar Upload */
        .avatar-upload {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .avatar-preview {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: #c97b42;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: bold;
        }

        .upload-area {
            border: 1px dashed #dcdfe4;
            border-radius: 8px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            background: #fafafa;
            flex: 1;
            max-width: 316px;
        }

        .upload-area:hover {
            background: #f4f5f7;
        }

        .upload-icon {
            width: 32px;
            height: 32px;
            background: white;
            border: 1px solid #eaeaea;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
        }

        @media (max-width: 768px) {
            .settings-container {
                padding: 20px;
            }

            .main-content {
                margin-left: 0;
                padding: 15px;
                margin-top: 70px;
            }

            .avatar-upload {
                flex-direction: column;
                align-items: flex-start;
            }

            .upload-area {
                max-width: 100%;
                width: 100%;
            }

            .form-control-custom,
            .input-group {
                max-width: 100% !important;
            }
        }
    </style>
</head>

<body>
    <%- include('./components/navbar', { activePage: 'settings' }) %>
        <%- include('./components/sidebar', { activePage: 'settings' }) %>

            <!-- MAIN -->
            <div class="main-content">
                <div class="settings-container">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <h1 class="settings-header">Settings</h1>
                        <i class="bi bi-three-dots-vertical text-muted cursor-pointer fs-5"></i>
                    </div>

                    <ul class="nav nav-tabs">
                        <li class="nav-item">
                            <a class="nav-link" href="/settings/account">Account</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link active" href="/settings/profile">Profile</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/settings/security">Security</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/settings">Appearance</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Notifications</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Billing</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Integrations</a>
                        </li>
                    </ul>

                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            <h5 class="section-title">Profile</h5>
                            <p class="section-desc">Manage your public profile and how you appear to others.</p>
                        </div>
                    </div>

                    <!-- Username -->
                    <div class="settings-row row align-items-start">
                        <div class="col-md-4 mb-3 mb-md-0">
                            <div class="section-title">Username</div>
                            <div class="section-desc">Will be displayed in community posts and interactions.</div>
                        </div>
                        <div class="col-md-8">
                            <div class="input-group" style="max-width: 400px;">
                                <span class="input-group-text bg-light text-muted border-end-0"
                                    style="font-size: 14px;">banksampah.com/</span>
                                <input type="text" class="form-control-custom border-start-0"
                                    style="border-top-left-radius: 0; border-bottom-left-radius: 0;"
                                    value="budisantoso">
                            </div>
                        </div>
                    </div>

                    <!-- Bio -->
                    <div class="settings-row row align-items-start">
                        <div class="col-md-4 mb-3 mb-md-0">
                            <div class="section-title">Bio</div>
                            <div class="section-desc">Write a short introduction about yourself.</div>
                        </div>
                        <div class="col-md-8">
                            <textarea class="form-control-custom"
                                placeholder="Tell us about your recycling habits..."></textarea>
                            <div class="text-muted mt-2" style="font-size: 13px;">275 characters left</div>
                        </div>
                    </div>

                    <!-- Avatar -->
                    <div class="settings-row row align-items-start">
                        <div class="col-md-4 mb-3 mb-md-0">
                            <div class="section-title">Profile photo</div>
                            <div class="section-desc">This will be displayed on your profile.</div>
                        </div>
                        <div class="col-md-8">
                            <div class="avatar-upload">
                                <div class="avatar-preview">B</div>
                                <div class="upload-area">
                                    <div class="upload-icon"><i class="bi bi-cloud-arrow-up text-muted"></i></div>
                                    <div style="font-size: 14px; color: #2E7D32; font-weight: 500; margin-bottom: 4px;">
                                        Click to upload <span class="text-muted fw-normal">or drag and drop</span></div>
                                    <div style="font-size: 12px; color: #6c757d;">SVG, PNG, JPG or GIF (max. 800x400px)
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Footer actions -->
                    <div class="row mt-4 pt-3" style="border-top: 1px solid #eaeaea;">
                        <div class="col-12 d-flex justify-content-end">
                            <button class="btn btn-cancel">Cancel</button>
                            <button class="btn btn-save">Save changes</button>
                        </div>
                    </div>
                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>