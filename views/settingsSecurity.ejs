<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Security Settings - Bank Sampah</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/layout.css">

    <style>
        body {
            background: #fdfdfd;
            font-family: 'Segoe UI', sans-serif;
            color: #333;
        }

        .settings-container {
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 1px 15px rgba(0, 0, 0, 0.04);
            padding: 30px;
            border: 1px solid #eef0f4;
            margin-bottom: 30px;
            max-width: 1000px;
        }

        .settings-header {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .nav-tabs {
            border-bottom: 1px solid #eaeaea;
            margin-bottom: 30px;
            flex-wrap: nowrap;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            padding-bottom: 2px;
        }

        /* Hide scrollbar for tabs */
        .nav-tabs::-webkit-scrollbar {
            display: none;
        }

        .nav-tabs {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .nav-tabs .nav-link {
            color: #6c757d;
            border: none;
            padding: 10px 15px;
            font-weight: 500;
            margin-bottom: -1px;
            position: relative;
        }

        .nav-tabs .nav-link:hover {
            color: #495057;
            border: none;
        }

        .nav-tabs .nav-link.active {
            color: #111;
            background: transparent;
            border: none;
        }

        .nav-tabs .nav-link.active::after {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            bottom: 0;
            height: 2px;
            background: #2E7D32;
        }

        .section-title {
            font-size: 16px;
            font-weight: 600;
            color: #212529;
            margin-bottom: 5px;
        }

        .section-desc {
            font-size: 14px;
            color: #6c757d;
            margin-bottom: 0;
        }

        .settings-row {
            padding: 25px 0;
            border-bottom: 1px solid #eaeaea;
        }

        .settings-row:last-child {
            border-bottom: none;
        }

        /* Form Controls */
        .form-control-custom {
            border: 1px solid #dcdfe4;
            border-radius: 6px;
            padding: 8px 12px;
            font-size: 14px;
            color: #333;
            width: 100%;
            max-width: 400px;
            background: #fff;
            font-weight: 500;
        }

        .form-control-custom:focus {
            outline: none;
            border-color: #2E7D32;
            box-shadow: 0 0 0 3px rgba(68, 76, 231, 0.1);
        }

        .btn-cancel {
            background: white;
            border: 1px solid #dcdfe4;
            color: #344054;
            font-weight: 600;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 14px;
        }

        .btn-cancel:hover {
            background: #f9fafb;
            color: #344054;
        }

        .btn-save {
            background: #2E7D32;
            border: 1px solid #2E7D32;
            color: white;
            font-weight: 600;
            border-radius: 8px;
            padding: 8px 16px;
            margin-left: 12px;
            font-size: 14px;
        }

        .btn-save:hover {
            background: #3538cd;
            color: white;
        }

        /* Toggles */
        .form-check-input-custom {
            width: 36px;
            height: 20px;
            background-color: #e2e8f0;
            border: none;
            border-radius: 20px;
            position: relative;
            appearance: none;
            cursor: pointer;
            transition: background-color 0.2s;
        }

        .form-check-input-custom::after {
            content: '';
            position: absolute;
            top: 2px;
            left: 2px;
            width: 16px;
            height: 16px;
            background-color: white;
            border-radius: 50%;
            transition: transform 0.2s;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
        }

        .form-check-input-custom:checked {
            background-color: #2E7D32;
        }

        .form-check-input-custom:checked::after {
            transform: translateX(16px);
        }

        @media (max-width: 768px) {
            .settings-container {
                padding: 20px;
            }

            .main-content {
                margin-left: 0;
                padding: 15px;
                margin-top: 70px;
            }

            .form-control-custom,
            .mb-3[style*="max-width"] {
                max-width: 100% !important;
            }

            .d-flex.justify-content-between.align-items-center.p-3 {
                flex-direction: column;
                align-items: flex-start !important;
                gap: 15px;
            }

            .form-check.form-switch {
                align-self: flex-end;
            }
        }
    </style>
</head>

<body>
    <%- include('./components/navbar', { activePage: 'settings' }) %>
        <%- include('./components/sidebar', { activePage: 'settings' }) %>

            <!-- MAIN -->
            <div class="main-content">
                <div class="settings-container">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <h1 class="settings-header">Settings</h1>
                        <i class="bi bi-three-dots-vertical text-muted cursor-pointer fs-5"></i>
                    </div>

                    <ul class="nav nav-tabs">
                        <li class="nav-item">
                            <a class="nav-link" href="/settings/account">Account</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/settings/profile">Profile</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link active" href="/settings/security">Security</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/settings">Appearance</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Notifications</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Billing</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Integrations</a>
                        </li>
                    </ul>

                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            <h5 class="section-title">Security</h5>
                            <p class="section-desc">Keep your account secure.</p>
                        </div>
                    </div>

                    <!-- Change Password -->
                    <div class="settings-row row align-items-start">
                        <div class="col-md-4 mb-3 mb-md-0">
                            <div class="section-title">Change password</div>
                            <div class="section-desc">Ensure your account is using a long, random password to stay
                                secure.</div>
                        </div>
                        <div class="col-md-8">
                            <div class="mb-3" style="max-width: 400px;">
                                <label class="form-label" style="font-size: 14px; font-weight: 500;">Current
                                    password</label>
                                <input type="password" class="form-control-custom">
                            </div>
                            <div class="mb-3" style="max-width: 400px;">
                                <label class="form-label" style="font-size: 14px; font-weight: 500;">New
                                    password</label>
                                <input type="password" class="form-control-custom">
                            </div>
                            <div class="mb-3" style="max-width: 400px;">
                                <label class="form-label" style="font-size: 14px; font-weight: 500;">Confirm new
                                    password</label>
                                <input type="password" class="form-control-custom">
                            </div>
                        </div>
                    </div>

                    <!-- 2FA -->
                    <div class="settings-row row align-items-center">
                        <div class="col-md-4 mb-3 mb-md-0">
                            <div class="section-title">Two-factor authentication</div>
                            <div class="section-desc">Add an extra layer of security to your account.</div>
                        </div>
                        <div class="col-md-8">
                            <div class="d-flex justify-content-between align-items-center p-3 rounded"
                                style="border: 1px solid #eaeaea; background: #fafafa; max-width: 400px;">
                                <div>
                                    <div style="font-size: 14px; font-weight: 600;">Authenticator app</div>
                                    <div class="text-muted" style="font-size: 13px;">Use an app to generate codes.</div>
                                </div>
                                <div class="form-check form-switch m-0 d-flex align-items-center">
                                    <input class="form-check-input-custom m-0" type="checkbox" role="switch">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Footer actions -->
                    <div class="row mt-4 pt-3" style="border-top: 1px solid #eaeaea;">
                        <div class="col-12 d-flex justify-content-end">
                            <button class="btn btn-cancel">Cancel</button>
                            <button class="btn btn-save">Update password</button>
                        </div>
                    </div>
                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>