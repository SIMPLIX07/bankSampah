            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                const MY_BALANCE = 200000;
                const FEE_EWALLET = 1000; // GoPay, OVO
                const FREE_METHODS = ['bca', 'bni', 'mandiri', 'bri'];

                // ── CURRENT FEE ──
                let currentFee = 0;

                function getCurrentFee() {
                    const method = document.querySelector('input[name="metode"]:checked');
                    if (!method) return 0;
                    return FREE_METHODS.includes(method.value) ? 0 : FEE_EWALLET;
                }

                // ── UPDATE SUMMARY ──
                function updateSummary() {
                    const method = document.querySelector('input[name="metode"]:checked');
                    const nominal = parseInt(document.getElementById('amountInput').value) || 0;
                    currentFee = getCurrentFee();
                    const total = Math.max(0, nominal - currentFee);

                    if (method) {
                        document.getElementById('sumMetode').textContent = method.value.toUpperCase();
                    }
                    document.getElementById('sumNominal').textContent = 'Rp ' + nominal.toLocaleString('id-ID');
                    document.getElementById('sumFee').textContent = currentFee === 0 ? 'Gratis' : 'Rp ' + currentFee.toLocaleString('id-ID');
                    document.getElementById('sumTotal').textContent = 'Rp ' + total.toLocaleString('id-ID');
                }

                // ── REKENING SUMMARY ──
                document.querySelectorAll('input[name="rekening"]').forEach(r => {
                    r.addEventListener('change', () => {
                        const lbl = r.closest('.rek-option').querySelector('.rek-num');
                        document.getElementById('sumRek').textContent = lbl ? lbl.textContent : '—';
                    });
                });

                // ── METHOD CHANGE ──
                document.querySelectorAll('input[name="metode"]').forEach(r => {
                    r.addEventListener('change', updateSummary);
                });

                // ── AMOUNT PRESETS ──
                document.querySelectorAll('.amount-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
                        document.getElementById('amountInput').value = btn.dataset.val;
                        updateSummary();
                    });
                });

                document.getElementById('amountInput').addEventListener('input', updateSummary);

                // ── ADD NEW REKENING TOGGLE ──
                function toggleNewRek() {
                    const f = document.getElementById('newAccountFields');
                    f.style.display = f.style.display === 'none' || f.style.display === '' ? 'block' : 'none';
                }

                // ── PIN AUTO-ADVANCE ──
                const pinInputs = document.querySelectorAll('.pin-digit');
                pinInputs.forEach((input, i) => {
                    input.addEventListener('input', () => {
                        // Only allow digits
                        input.value = input.value.replace(/[^0-9]/g, '');
                        if (input.value && i < pinInputs.length - 1) {
                            pinInputs[i + 1].focus();
                        }
                    });
                    input.addEventListener('keydown', e => {
                        if (e.key === 'Backspace' && !input.value && i > 0) {
                            pinInputs[i - 1].focus();
                        }
                    });
                });

                // Init
                updateSummary();
            </script>
